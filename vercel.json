{
  "version": 2,
  "builds": [
    {
      "src": "locentra-app/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/locentra-app/build/static/$1"
    },
    {
      "src": "/models/(.*)",
      "dest": "/locentra-app/build/models/$1"
    },
    {
      "src": "/data/(.*)",
      "dest": "/locentra-app/build/data/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/locentra-app/build/index.html"
    }
  ]
}
