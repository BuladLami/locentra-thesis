{
  "buildCommand": "cd locentra-app && npm install && npm run build",
  "outputDirectory": "locentra-app/build",
  "devCommand": "cd locentra-app && npm start",
  "installCommand": "cd locentra-app && npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
